# SecureVault Environment Configuration
# Copy this to .env and fill in your values

# --- Required ---
JWT_SECRET=replace-this-with-a-long-random-string-in-production

# --- Database ---
# Default is SQLite (good for dev and self-hosted)
# For PostgreSQL: postgresql+asyncpg://user:password@host/dbname
DATABASE_URL=securevault.db

# --- Server ---
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development   # development | production

# --- CORS ---
# Comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
